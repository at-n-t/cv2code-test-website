# CV2CC — Environment variable template
# Copy this to .env and fill in real values. Never commit .env.

# Flask session secret (generate a strong random string for production)
CV2CC_SECRET=change-me-to-a-strong-random-secret

# Anthropic API key — get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here
